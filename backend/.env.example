# Server
PORT=3000
NODE_ENV=production

# CORS — your Vercel frontend URL (comma-separated for multiple)
FRONTEND_URL=https://your-app.vercel.app

# PostgreSQL — Railway sets DATABASE_URL automatically when you add the plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis — Railway sets REDIS_URL automatically when you add the plugin
# Optional — without it the app still works, just without caching
REDIS_URL=redis://default:password@host:6379
